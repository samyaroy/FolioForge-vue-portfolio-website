{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "folioforge-blog",
  "compatibility_date": "2026-03-21",
  // SPA: serve index.html for unknown paths so client-side routes
  // (e.g. /posts/:slug) work on refresh and direct links.
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
